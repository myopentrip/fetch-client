{
  "name": "@myopentrip/fetch-client",
  "version": "3.1.0",
  "description": "A lightweight fetch wrapper with optional auth, upload, and SSL plugins",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "import": "./dist/auth.mjs",
      "require": "./dist/auth.js"
    },
    "./upload": {
      "types": "./dist/upload.d.ts",
      "import": "./dist/upload.mjs",
      "require": "./dist/upload.js"
    },
    "./ssl": {
      "types": "./dist/ssl.d.ts",
      "import": "./dist/ssl.mjs",
      "require": "./dist/ssl.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.mjs",
      "require": "./dist/app.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "example": "tsx examples/example.ts",
    "example:core": "tsx examples/core-patterns-example.ts",
    "example:combined": "tsx examples/combined-plugins-example.ts",
    "example:advanced": "tsx examples/advanced-example.ts",
    "example:interceptors": "tsx examples/interceptor-examples.ts",
    "example:auth": "tsx examples/auth-examples.ts",
    "example:auth:401": "tsx examples/auth-401-retry-example.ts",
    "example:auth:lifecycle": "tsx examples/auth-lifecycle-example.ts",
    "example:cookie": "tsx examples/cookie-auth-examples.ts",
    "example:upload": "tsx examples/file-upload-examples.ts",
    "example:ssl": "tsx examples/ssl-error-examples.ts",
    "example:errors": "tsx examples/http-errors-example.ts"
  },
  "keywords": [
    "fetch",
    "http",
    "client",
    "api",
    "typescript",
    "javascript"
  ],
  "author": "Bliss Jaspis",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "pnpm@10.12.1",
  "devDependencies": {
    "@types/node": "^24.12.4",
    "tsup": "^8.5.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/myopentrip/fetch-client.git"
  }
}
